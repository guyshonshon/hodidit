# AI provider selection: auto | openai | gemini
AI_PROVIDER=auto

# OpenAI (paid API)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini (free tier available)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional GitHub integration for /push-github endpoint
GITHUB_TOKEN=
GITHUB_REPO=

# API key — protects all /labs/* endpoints (leave empty to disable auth)
# Backend: API_KEY=your-secret-here
# Frontend: VITE_API_KEY=your-secret-here  (must match)
API_KEY=
VITE_API_KEY=

# Scraper and backend runtime settings
TARGET_SITE_URL=https://hothaifa96.github.io/DevSecOps22/
SCRAPE_INTERVAL_MINUTES=60
DATABASE_URL=sqlite:///./devops_solver.db
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
MAX_REPAIR_RETRIES=3

# 4-digit PIN required to trigger a manual sync from the UI (leave empty to disable)
SYNC_PIN=

# Optional Cloudflare tunnel profile in docker compose
CLOUDFLARE_TUNNEL_TOKEN=
